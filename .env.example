# =============================================================================
# C-Vault Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env file with real secrets to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string for Neon or any PostgreSQL database
# Format: postgresql://username:password@host:port/database?sslmode=require
# Example: postgresql://myuser:mypass@ep-cool-darkness-123456.us-east-2.aws.neon.tech:5432/cvault?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/cvault?sslmode=require"

# -----------------------------------------------------------------------------
# NextAuth.js Configuration
# -----------------------------------------------------------------------------
# The base URL of your application (change in production)
NEXTAUTH_URL="http://localhost:3000"

# Secret key for NextAuth.js session encryption
# Generate with: openssl rand -base64 32
# IMPORTANT: Generate a new secret for production!
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# -----------------------------------------------------------------------------
# IBM watsonx.ai Configuration
# -----------------------------------------------------------------------------
# IBM Cloud API key for watsonx.ai access
# Get from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY="your-watsonx-api-key"

# watsonx.ai project ID where your models are deployed
# Find in your watsonx.ai project settings
WATSONX_PROJECT_ID="your-watsonx-project-id"

# watsonx.ai API endpoint URL (region-specific)
# Common values:
# - US South: https://us-south.ml.cloud.ibm.com
# - EU Germany: https://eu-de.ml.cloud.ibm.com
# - Japan Tokyo: https://jp-tok.ml.cloud.ibm.com
WATSONX_URL="https://us-south.ml.cloud.ibm.com"

# Model to use for generation. Defaults to ibm/granite-3-8b-instruct in code
# if unset — set explicitly here so it's visible/changeable without a code edit.
WATSONX_MODEL_ID="ibm/granite-3-8b-instruct"

# -----------------------------------------------------------------------------
# IPFS Anchoring (Optional)
# -----------------------------------------------------------------------------
# Pinata JWT for pinning version content to IPFS as an external provenance record
# Get from: https://app.pinata.cloud/developers/api-keys
# Leave empty to disable the "Anchor to IPFS" action in the provenance timeline
PINATA_JWT="your-pinata-jwt"

# Public gateway used to build the "view on IPFS" link
NEXT_PUBLIC_IPFS_GATEWAY="https://gateway.pinata.cloud/ipfs"

# -----------------------------------------------------------------------------
# Redis Configuration (Optional)
# -----------------------------------------------------------------------------
# Upstash Redis for rate limiting and caching
# Sign up at: https://upstash.com
# Leave empty to disable Redis-based features
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Node environment: development, production, or test
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Rate Limiting Configuration (Optional)
# -----------------------------------------------------------------------------
# Maximum number of requests per time window
# Default: 100 requests
RATE_LIMIT_MAX_REQUESTS="100"

# Time window in milliseconds for rate limiting
# Default: 60000ms (1 minute)
RATE_LIMIT_WINDOW_MS="60000"